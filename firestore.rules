rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ULTIMATE EMERGENCY OPEN SESAME
    // Allowing anyone to read and write for the next 2 months for setup.
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 7, 1);
    }
  }
}
